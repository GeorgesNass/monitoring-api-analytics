###############################################################################
# General
###############################################################################
ENVIRONMENT=dev
LOG_LEVEL=INFO

###############################################################################
# Paths
###############################################################################
DATA_DIR=./data
RAW_DIR=./data/raw
INTERIM_DIR=./data/interim
PROCESSED_DIR=./data/processed

ARTIFACTS_DIR=./artifacts
LOGS_DIR=./logs

###############################################################################
# Google Cloud
###############################################################################
GCP_PROJECT_ID=<YOUR_GCP_PROJECT_ID_HERE>
BQ_DATASET=<YOUR_BIGQUERY_DATASET_HERE>
BQ_TABLE=<YOUR_BIGQUERY_TABLE_HERE>
GOOGLE_APPLICATION_CREDENTIALS=<YOUR_SERVICE_ACCOUNT_JSON_PATH_HERE>

###############################################################################
# BigQuery (Dashboard Tables)
###############################################################################
BQ_LOCATION=EU
BQ_TABLE_NORMALIZED=<YOUR_NORMALIZED_TABLE_NAME_HERE>
BQ_TABLE_LATENCY=<YOUR_LATENCY_TABLE_NAME_HERE>
BQ_TABLE_ERRORS=<YOUR_ERRORS_TABLE_NAME_HERE>
BQ_TABLE_STATUS=<YOUR_STATUS_TABLE_NAME_HERE>
BQ_TABLE_SLA=<YOUR_SLA_TABLE_NAME_HERE>

###############################################################################
# SQLite (local alternative)
###############################################################################
SQLITE_DB_PATH=./data/processed/monitoring.db

###############################################################################
# API
###############################################################################
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true