## ============================================
## General
## ============================================
ENVIRONMENT=dev
LOG_LEVEL=INFO

## ============================================
## Paths
## ============================================
DATA_DIR=./data
RAW_DIR=./data/raw
INTERIM_DIR=./data/interim
PROCESSED_DIR=./data/processed

ARTIFACTS_DIR=./artifacts
LOGS_DIR=./logs

## ============================================
## GOOGLE CLOUD (JSON CONFIG + SERVICE ACCOUNT)
## ============================================
GCP_CONFIG_FILE=secrets/gcp_config.json ## (project + BigQuery)
GOOGLE_APPLICATION_CREDENTIALS_FILE=secrets/gcp_service_account.json

## ============================================
## ANOMALY DETECTION
## ============================================
ANOMALY_DETECTION_ENABLED=true
ANOMALY_METHOD=zscore
Z_THRESHOLD=3.0
IQR_MULTIPLIER=1.5
ANOMALY_STRICT_MODE=false
MONITORING_STREAMING_ENABLED=true

## ============================================
## BigQuery (Dashboard Tables)
## ============================================
BQ_LOCATION=EU
BQ_TABLE_NORMALIZED=<YOUR_NORMALIZED_TABLE_NAME_HERE>
BQ_TABLE_LATENCY=<YOUR_LATENCY_TABLE_NAME_HERE>
BQ_TABLE_ERRORS=<YOUR_ERRORS_TABLE_NAME_HERE>
BQ_TABLE_STATUS=<YOUR_STATUS_TABLE_NAME_HERE>
BQ_TABLE_SLA=<YOUR_SLA_TABLE_NAME_HERE>

## ============================================
## SQLite (local alternative)
## ============================================
SQLITE_DB_PATH=./data/processed/monitoring.db

## ============================================
## API
## ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true